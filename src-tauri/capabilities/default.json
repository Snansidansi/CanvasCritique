{
  "$schema": "../capabilities-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the CanvasCritique application window.",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "dialog:default",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" },
        { "url": "http://*/**" },
        { "url": "https://*/**" },
        { "url": "http://*:*" },
        { "url": "https://*:*" },
        { "url": "http://*:*/*" },
        { "url": "https://*:*/*" },
        { "url": "http://*:*/**" },
        { "url": "https://*:*/**" },
        { "url": "http://**" },
        { "url": "https://**" },
        { "url": "http://**/**" },
        { "url": "https://**/**" }
      ]
    },
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "core:webview:allow-set-webview-zoom"
  ]
}
