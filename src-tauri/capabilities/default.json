{
  "$schema": "../capabilities-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the CanvasCritique application window.",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "core:webview:allow-set-webview-zoom"
  ]
}
